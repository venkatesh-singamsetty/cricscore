#!/usr/bin/env sh

echo "🔒 Scanning for secrets in staged files before committing..."
if command -v gitleaks &> /dev/null; then
  # Run gitleaks to check for secrets in files about to be committed
  gitleaks protect -v --staged
else
  echo "⚠️  gitleaks is not installed. Skipping secrets scan."
  echo "Run ./scripts/setup.sh to install it."
fi
