# ==============================================================================
# Node.js & Dependencies
# ==============================================================================
# Ignore all dependencies downloaded via npm/yarn/pnpm
node_modules/
jspm_packages/

# ==============================================================================
# Build & Output
# ==============================================================================
# Production build folder (Vite default)
dist/
dist-ssr/

# Static site generators or other build artifacts
.cache/

# ==============================================================================
# Terraform & Infrastructure
# ==============================================================================
# Ignore local terraform state and binary files
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore variables file containing secrets (terraform.tfvars MUST be ignored for security)
terraform.tfvars
*.auto.tfvars
infra/terraform/*.zip
apps/backend/**/node_modules/

# Ignore terraform plan files
*.tfplan

# ==============================================================================
# Logs & Runtime
# ==============================================================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==============================================================================
# Environment & Secrets
# ==============================================================================
# Certificates and Keys
certs/
*.pem
*.key

# ==============================================================================
# IDEs & Text Editors
# ==============================================================================
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# IntelliJ / WebStorm
.idea/
*.iws
*.iml
*.ipr

# Other editors
*.sw?
*~
# Visual Studio
*.suo
*.ntvs*
*.njsproj
*.sln

# ==============================================================================
# Operating System Specific
# ==============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# Linux
.fuse_hidden
.directory
.Trash-*

# ==============================================================================
# Testing
# ==============================================================================
# Coverage reports
coverage/
.nyc_output/
.env
# Local environment overrides (may contain secrets)
.env.local

# Local helper scripts containing plaintext secrets
setup-secrets.sh

# Playwright Test Reports
apps/e2e/playwright-report/
apps/e2e/test-results/
apps/e2e/playwright/.cache/
