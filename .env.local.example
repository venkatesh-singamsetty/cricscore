# ------------------------------------------------------------------------------
# CricScore Local Infrastructure Configuration Template
# Copy this file to `.env.local` and replace the dummy values with your actual config.
# WARNING: Do NOT commit `.env.local` to version control.
# ------------------------------------------------------------------------------

# --------------------
# 1) AWS Credentials & Config
# Uncomment only for quick local testing; do NOT commit these values.
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION='us-east-1'
AWS_DEFAULT_REGION='us-east-1'

# --------------------
# 2) Database & Email (SENSITIVE)
TF_DATABASE_URL='postgres://avnadmin:dummy_password@cricscore-pg-example.aivencloud.com:25060/defaultdb?sslmode=require'
TF_SES_SOURCE_EMAIL='noreply@example.com'
ADMIN_EMAIL='admin@example.com'

# --------------------
# 3) Project & Domain Configuration
DOMAIN_NAME='cricscore.example.com'
ZONE_DOMAIN='example.com'
SUBDOMAIN_PREFIX='cricscore'
PROJECT_NAME='cricscore'

# --------------------
# 4) Frontend & Deploy Outputs
# These will be automatically populated/used by the deployment script
S3_BUCKET=dummy-cricscore-app-bucket
CLOUDFRONT_DISTRIBUTION_ID=DUMMYDISTID123
