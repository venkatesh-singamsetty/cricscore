# ------------------------------------------------------------------------------
# CricScore Frontend Environment Template
# Copy this file to `apps/frontend/.env` and replace the values.
# WARNING: Do NOT commit `apps/frontend/.env` to version control.
# ------------------------------------------------------------------------------

# AWS API Gateway URLs (These will be automatically appended here by ./infra/scripts/deploy.sh)
VITE_API_URL=https://dummy-api-id.execute-api.us-east-1.amazonaws.com
VITE_WS_URL=wss://dummy-ws-id.execute-api.us-east-1.amazonaws.com/prod

# The secret PIN required for the scorer/admin dashboard
VITE_ADMIN_PIN=123456

# The default email address to pre-fill in the scorer login
VITE_DEFAULT_EMAIL=admin@example.com

# (Optional) Sentry Crash Reporting Data Source Name
VITE_SENTRY_DSN=
