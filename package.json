{
  "name": "cricscore-workspace",
  "private": true,
  "version": "2.8.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --prefix apps/frontend",
    "build": "npm run build --prefix apps/frontend",
    "preview": "npm run preview --prefix apps/frontend",
    "lint": "npm run lint --prefix apps/frontend",
    "test": "npm run test --prefix apps/frontend",
    "test:all": "npm run test --prefix apps/frontend && npm run test --prefix apps/backend",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ]
  }
}
